# Infrastructure credentials used by docker-compose.production.yml
REDIS_PASSWORD=darkwallet
POSTGRES_PASSWORD=darkwallet
SSL_CERT_BASE=/etc/letsencrypt/live
SSL_DOMAIN=localhost

# Prover runtime
MIDNIGHT_NETWORK=standalone
PORT=4000

# API and data protection
MIDLIGHT_API_SECRET=
MIDLIGHT_ENCRYPTION_KEY=
MIDLIGHT_TLS_CERT=
MIDLIGHT_TLS_KEY=

# Midnight wallet and prover
MIDNIGHT_WALLET_SEED=
MIDLIGHT_ZK_CONFIG_PATH=
MIDLIGHT_STATE_PATH=

# Network endpoints (optional in standalone; defaults are applied)
MIDNIGHT_INDEXER_HTTP=
MIDNIGHT_INDEXER_WS=
MIDNIGHT_NODE_HTTP=
MIDNIGHT_PROOF_SERVER_HTTP=

# Queue + storage
MIDLIGHT_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
MIDLIGHT_DATABASE_URL=postgres://darkwallet:${POSTGRES_PASSWORD}@postgres:5432/darkwallet

# Attestation + oracle
BLOCKFROST_PROJECT_ID=
BLOCKFROST_BASE_URL=
ATTESTATION_TTL_MS=300000
ATTESTATION_MAX_CLOCK_SKEW_MS=30000
ATTESTATION_PROOF_VALIDITY_MS=86400000
MIDLIGHT_MIN_L1_ADA_LOVELACE=5000000
MIDLIGHT_ORACLE_PRIVATE_KEY=
MIDLIGHT_ORACLE_PUBLIC_KEY=
MIDLIGHT_ORACLE_DOMAIN_TAG=darkwallet:oracle:v1

# Intent + legacy compatibility
MIDLIGHT_ENABLE_ATTESTATION_ENFORCEMENT=false
MIDLIGHT_ENABLE_INTENT_SIGNING=true
MIDLIGHT_ALLOW_LEGACY_JOB_ENDPOINTS=true

# Relayer gas slots + workers
MIDLIGHT_RELAYER_GAS_SLOT_COUNT=64
MIDLIGHT_RELAYER_GAS_SLOT_VALUE_DUST=5
MIDLIGHT_RELAYER_GAS_LEASE_TTL_MS=120000
MIDLIGHT_JOB_CONCURRENCY=2
MIDLIGHT_PROCESS_ROLE=all
